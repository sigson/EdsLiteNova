<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Eds.Maui.ViewModels"
             x:Class="Eds.Maui.Views.ChangePasswordPage"
             x:DataType="vm:ChangePasswordViewModel"
             Title="Change password">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{Binding Title}" FontSize="20" FontAttributes="Bold" />
            <Entry Placeholder="New password" IsPassword="True" Text="{Binding NewPassword}" />
            <Entry Placeholder="Confirm new password" IsPassword="True" Text="{Binding ConfirmPassword}" />
            <HorizontalStackLayout Spacing="8">
                <Label Text="PIM (VeraCrypt, 0 = default)" VerticalOptions="Center" />
                <Entry Text="{Binding Pim}" Keyboard="Numeric" WidthRequest="90" />
            </HorizontalStackLayout>
            <Button Text="Change password" Command="{Binding ChangeCommand}"
                    IsEnabled="{Binding Busy, Converter={StaticResource Not}}" />
            <ActivityIndicator IsRunning="{Binding Busy}" />
            <Label Text="{Binding Status}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
