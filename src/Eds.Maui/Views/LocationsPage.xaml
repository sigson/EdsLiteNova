<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Eds.Maui.ViewModels"
             x:Class="Eds.Maui.Views.LocationsPage"
             x:DataType="vm:LocationsViewModel"
             Title="Locations">
    <Grid RowDefinitions="Auto,*,Auto" Padding="12" RowSpacing="8">

        <HorizontalStackLayout Grid.Row="0" Spacing="8">
            <Button Text="＋ Container" Command="{Binding AddContainerCommand}" />
            <Button Text="＋ EncFS folder" Command="{Binding AddEncFsCommand}" />
            <Button Text="⟳" Command="{Binding RefreshCommand}" />
        </HorizontalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Locations}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:LocationItem">
                    <Grid Padding="10,10" ColumnDefinitions="Auto,*,Auto,Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.OpenCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="{Binding Glyph}" FontSize="22" Margin="0,0,10,0" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="{Binding Title}" FontAttributes="Bold" />
                            <Label Text="{Binding StateText}" FontSize="12" TextColor="#888" />
                        </VerticalStackLayout>
                        <Button Grid.Column="2" Text="Close" FontSize="12" Padding="8,0" Margin="4,0"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.CloseCommand}"
                                CommandParameter="{Binding .}"
                                IsVisible="{Binding IsOpen}" />
                        <Button Grid.Column="3" Text="🗑" FontSize="14" Padding="8,0"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.RemoveCommand}"
                                CommandParameter="{Binding .}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="2" Text="{Binding Status}" FontSize="12" TextColor="#666" />
    </Grid>
</ContentPage>
